                    <arrayElement
                      dataType="System.String"><![CDATA[using System;
using Microsoft.SqlServer.Dts.Pipeline.Wrapper;
using Microsoft.SqlServer.Dts.Runtime.Wrapper;

[Microsoft.SqlServer.Dts.Pipeline.SSISScriptComponentEntryPoint]
public class ScriptMain : UserComponent
{
    public override void CreateNewOutputRows()
    {
        DateTime startDate = new DateTime(2015, 1, 1);   // change if needed
        DateTime endDate = new DateTime(2022, 12, 31); // change if needed

        for (DateTime d = startDate; d <= endDate; d = d.AddDays(1))
        {
            Output0Buffer.AddRow();

            Output0Buffer.DateKey = d.Year * 10000 + d.Month * 100 + d.Day;
            Output0Buffer.FullDate = d;
            Output0Buffer.Day = d.Day;
            Output0Buffer.DayName = d.DayOfWeek.ToString();
            Output0Buffer.Month = d.Month;
            Output0Buffer.MonthName = d.ToString("MMMM");
            Output0Buffer.Quarter = ((d.Month - 1) / 3) + 1;
            Output0Buffer.Year = d.Year;
            Output0Buffer.IsWeekend = (d.DayOfWeek == DayOfWeek.Saturday || d.DayOfWeek == DayOfWeek.Sunday);
        }
    }
}]]></arrayElement>
