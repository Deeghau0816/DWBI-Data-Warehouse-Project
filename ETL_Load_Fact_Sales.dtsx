                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT
    CAST(Customer_ID AS INT) AS Customer_ID,
    Customer_Status,
    TRY_CONVERT(DATE, [Date_Order_was_placed], 6) AS Order_Date,
    TRY_CONVERT(DATE, [Delivery_Date], 6) AS Delivery_Date,
    CAST(Order_ID AS BIGINT) AS Order_ID,
    CAST(Product_ID AS BIGINT) AS Product_ID,
    CAST(Quantity_Ordered AS INT) AS Quantity_Ordered,
    CAST([Total_Retail_Price_for_This_Order] AS DECIMAL(18,2)) AS Total_Retail_Price,
    CAST([Cost_Price_Per_Unit] AS DECIMAL(18,2)) AS Cost_Price_Per_Unit
FROM dbo.Raw_Orders;</property>
